const { useState, useEffect, useRef } = React;

/* ===== SMOKE CANVAS — cinematic ember diffusion ===== */
function SmokeCanvas() {
  const canvasRef = useRef(null);
  const sparkRef = useRef(null);
  useEffect(() => {
    const canvas = canvasRef.current;
    const sparkCanvas = sparkRef.current;
    if (!canvas || !sparkCanvas) return;
    const ctx = canvas.getContext('2d');
    const sctx = sparkCanvas.getContext('2d');
    let w, h, raf, dpr;
    const smoke = [];
    const sparks = [];

    const resize = () => {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = canvas.width = sparkCanvas.width = window.innerWidth * dpr;
      h = canvas.height = sparkCanvas.height = window.innerHeight * dpr;
      [canvas, sparkCanvas].forEach((c) => {
        c.style.width = window.innerWidth + 'px';
        c.style.height = window.innerHeight + 'px';
      });
    };
    resize();
    window.addEventListener('resize', resize);

    // soft, large diffusion blobs (smoke body)
    const spawnSmoke = () => {
      if (smoke.length > 12) return;
      const px = Math.random();
      smoke.push({
        x: px * 0.15 * w,
        y: h * (0.75 + Math.random() * 0.28),
        vx: 0.10 + Math.random() * 0.22,
        vy: -0.16 - Math.random() * 0.28,
        r: (90 + Math.random() * 130) * dpr,
        life: 0,
        maxLife: 360 + Math.random() * 240,
        hue: [10, 18, 28, 36][Math.floor(Math.random() * 4)],
        sat: 82 + Math.random() * 8,
        light: 42 + Math.random() * 8,
        alpha: 0.006 + Math.random() * 0.006,
        drift: Math.random() * Math.PI * 2
      });
    };

    // tiny floating embers (light bloom highlights)
    const spawnSpark = () => {
      if (sparks.length > 14) return;
      sparks.push({
        x: Math.random() * w * 0.22,
        y: h * (0.85 + Math.random() * 0.15),
        vx: 0.08 + Math.random() * 0.25,
        vy: -0.4 - Math.random() * 0.7,
        r: (1.2 + Math.random() * 2.2) * dpr,
        life: 0,
        maxLife: 180 + Math.random() * 160,
        hue: 28 + Math.random() * 14,
        alpha: 0.5 + Math.random() * 0.4,
        wobble: Math.random() * Math.PI * 2
      });
    };

    let frame = 0;
    const tick = () => {
      // smoke layer — gentle fade trail for soft diffusion
      ctx.globalCompositeOperation = 'source-over';
      ctx.fillStyle = 'rgba(6, 6, 6, 0.06)';
      ctx.fillRect(0, 0, w, h);

      ctx.globalCompositeOperation = 'lighter';
      if (frame % 10 === 0) spawnSmoke();
      for (let i = smoke.length - 1; i >= 0; i--) {
        const p = smoke[i];
        p.life++;
        p.drift += 0.008;
        p.x += p.vx + Math.sin(p.drift) * 0.25;
        p.y += p.vy + Math.cos(p.drift * 0.7) * 0.12;
        p.r += 0.55;
        const t = p.life / p.maxLife;
        // smooth ease in/out for soft entry & exit
        const env = Math.sin(t * Math.PI);
        const a = p.alpha * env;
        const grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r);
        grd.addColorStop(0, `hsla(${p.hue}, ${p.sat}%, ${p.light + 6}%, ${a})`);
        grd.addColorStop(0.35, `hsla(${p.hue - 4}, ${p.sat}%, ${p.light}%, ${a * 0.55})`);
        grd.addColorStop(0.7, `hsla(${p.hue - 8}, ${p.sat}%, ${p.light - 8}%, ${a * 0.18})`);
        grd.addColorStop(1, `hsla(${p.hue - 10}, 80%, 40%, 0)`);
        ctx.fillStyle = grd;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
        if (p.life > p.maxLife) smoke.splice(i, 1);
      }

      // spark layer (separate canvas for crisp bloom)
      sctx.clearRect(0, 0, w, h);
      sctx.globalCompositeOperation = 'lighter';
      if (frame % 14 === 0) spawnSpark();
      for (let i = sparks.length - 1; i >= 0; i--) {
        const s = sparks[i];
        s.life++;
        s.wobble += 0.05;
        s.x += s.vx + Math.sin(s.wobble) * 0.4;
        s.y += s.vy;
        s.vy += 0.002; // slight float
        const t = s.life / s.maxLife;
        const env = Math.sin(t * Math.PI);
        const a = s.alpha * env;
        // glow halo
        const halo = sctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, s.r * 8);
        halo.addColorStop(0, `hsla(${s.hue}, 100%, 70%, ${a * 0.45})`);
        halo.addColorStop(0.4, `hsla(${s.hue}, 100%, 55%, ${a * 0.15})`);
        halo.addColorStop(1, `hsla(${s.hue}, 100%, 50%, 0)`);
        sctx.fillStyle = halo;
        sctx.beginPath();
        sctx.arc(s.x, s.y, s.r * 8, 0, Math.PI * 2);
        sctx.fill();
        // hot core
        sctx.fillStyle = `hsla(${s.hue + 10}, 100%, 88%, ${a})`;
        sctx.beginPath();
        sctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        sctx.fill();
        if (s.life > s.maxLife) sparks.splice(i, 1);
      }

      frame++;
      raf = requestAnimationFrame(tick);
    };
    tick();
    return () => {cancelAnimationFrame(raf);window.removeEventListener('resize', resize);};
  }, []);
  return (
    <>
      <canvas id="smoke" ref={canvasRef}></canvas>
      <canvas id="sparks" ref={sparkRef}></canvas>
    </>);

}

